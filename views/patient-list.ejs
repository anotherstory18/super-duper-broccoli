<%- include('partials/header') %>
<h2>Patient List</h2>
<form class="inline"><input name="search" value="<%= search %>" placeholder="Search by ID or phone" /><button class="btn">Search</button></form>
<table><tr><th>ID</th><th>Name</th><th>Phone</th><th>Department</th><th>Emergency</th></tr>
<% patients.forEach(p=> { %><tr><td><%= p.id %></td><td><%= p.name %></td><td><%= p.phone %></td><td><%= p.department %></td><td><%= p.emergency ? 'Yes':'No' %></td></tr><% }) %>
</table>
<%- include('partials/footer') %>
